FROM richarvey/php-fpm-laravel:3.0.0

# Set working directory
WORKDIR /var/www/html

# Copy project files
COPY . .

# Environment setup
ENV APP_ENV=production
ENV APP_DEBUG=false
ENV PHP_ERRORS_STDERR=1
ENV COMPOSER_ALLOW_SUPERUSER=1

# Install dependencies
RUN composer install --no-dev --optimize-autoloader

# Build assets
RUN npm install && npm run build

# Set permissions
RUN chown -R www-data:www-data /var/www/html/storage /var/www/html/cache

# Expose port (Matching what artisan serve or the image might use)
EXPOSE 8000

# Use a custom start command to handle migrations and start the server
# This avoids the interactive prompt
CMD php artisan migrate --force && php artisan serve --host 0.0.0.0 --port 8000
